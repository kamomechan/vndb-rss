# .env文件属性值默认为字符串(即使不加引号)，如需数字类型需在引用后显示转换 例如：Number(process.env.CACHE_TIME)
TOKEN=""
PORT="3000"
HOST="127.0.0.1"
FEED_NUMBER="20"
# 5分钟缓存时间 5 * 60 * 1000
CACHE_TIME="300000"
# 自定义排除标签，逗号分隔多个标签，标签编号请查看: https://vndb.org/g
RECLUDE_TAG="g3723"
# 自定义排除版本(仅官方版本生效)，逗号分隔多个版本，可选值: "trial", "partial" , "complete"
RECLUDE_VERSION="trial"